{
  "schema_version": 1,
  "python_versions": [
    "3.11",
    "3.12",
    "3.13"
  ],
  "required_corpus_categories": [
    "simple_document",
    "multi_section_form",
    "control_rich",
    "complex_layout",
    "hard_case",
    "legacy_binary"
  ],
  "minimum_case_counts": {
    "hwpx_stability": 72,
    "hwp_stability": 76,
    "bridge_stability": 25
  },
  "thresholds": {
    "pytest_failures_max": 0,
    "corpus_failures_max": 0,
    "hwpx_stability_failures_max": 0,
    "hwp_stability_failures_max": 0,
    "bridge_stability_failures_max": 0,
    "hancom_corpus_failures_max": 0,
    "hancom_dialogs_max": 0,
    "pdf_visual_diff_max_changed_ratio": 0.005
  },
  "supported_scopes": [
    {
      "format": "HWPX",
      "tier": "strong_roundtrip",
      "operations": [
        "open existing documents",
        "blank document authoring",
        "text replacement and paragraph editing",
        "table, picture, equation, shape insertion",
        "header and footer editing",
        "bookmark and field editing",
        "multi-section editing"
      ],
      "gates": [
        "pytest",
        "corpus_validation",
        "hwpx_stability_lab",
        "hancom_corpus_smoke"
      ]
    },
    {
      "format": "HWP",
      "tier": "constrained_binary_editing",
      "operations": [
        "open existing binary documents",
        "preview and body text extraction",
        "same-length text replacement",
        "profile-backed paragraph, table, picture, hyperlink, bookmark, note, and section editing",
        "reopen after save"
      ],
      "gates": [
        "pytest",
        "hwp_stability_lab"
      ]
    },
    {
      "format": "HWP<->HWPX",
      "tier": "semantic_bridge_roundtrip",
      "operations": [
        "hwp to hwpx conversion",
        "hwpx to hwp conversion",
        "bridge-backed paragraph, table, hyperlink, equation, shape, ole, section, and note edits",
        "reopen after bridge save"
      ],
      "gates": [
        "pytest",
        "bridge_stability_lab"
      ]
    }
  ],
  "unsupported_scopes": [
    "Byte-identical HWP to HWPX or HWPX to HWP conversion is not guaranteed.",
    "Pure-Python HWP writing is not a promise of full-fidelity preservation for every legacy HWP control or every arbitrary third-party document.",
    "Unsupported or unknown HWP binary controls are not guaranteed to round-trip unless a profile or donor-backed path explicitly covers them.",
    "Pixel-identical layout parity with Hancom is not guaranteed; the hard release blocker is zero structural layout-signature regressions and zero Hancom warning or recovery dialogs on the release corpus.",
    "PDF visual diff remains advisory until a renderer-backed baseline is wired into the repository gate."
  ],
  "gate_profiles": {
    "ci": {
      "description": "Portable release gate that runs on CI without Hancom.",
      "run_pytest": true,
      "run_packaging": true,
      "run_corpus_validation": true,
      "run_hwpx_stability_lab": true,
      "run_hwp_stability_lab": true,
      "run_bridge_stability_lab": true,
      "require_windows": false,
      "require_hancom": false,
      "run_hancom_corpus_smoke": false
    },
    "release": {
      "description": "Full release gate for a Windows machine with Hancom installed.",
      "run_pytest": true,
      "run_packaging": true,
      "run_corpus_validation": true,
      "run_hwpx_stability_lab": true,
      "run_hwp_stability_lab": true,
      "run_bridge_stability_lab": true,
      "require_windows": true,
      "require_hancom": true,
      "run_hancom_corpus_smoke": true
    }
  },
